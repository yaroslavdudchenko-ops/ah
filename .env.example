# Research Protocols - AI Protocol Generator
# Copy this file to .env and fill in sensitive values
# DO NOT commit .env to version control

# ============================================
# Application
# ============================================
APP_ENV=development
LOG_LEVEL=info

# ============================================
# Database - PostgreSQL (docker-compose: db)
# ============================================
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=protocols
DATABASE_URL=postgresql+asyncpg://app:CHANGE_ME@db:5432/protocols
DB_PORT=5432

# ============================================
# AI - OpenRouter (public fallback)
# ============================================
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ============================================
# AI - Internal API Gateway (priority)
# Leave empty to fall back to OpenRouter
# ============================================
AI_GATEWAY_URL=
AI_GATEWAY_API_KEY=

# ============================================
# GitLab MCP (mcp.json - gitlab server)
# PAT scopes: api + read_repository
# ============================================
GITLAB_API_URL=https://gitlab.biocad.ru
GITLAB_PERSONAL_ACCESS_TOKEN=

# ============================================
# Atlassian MCP (mcp.json - mcp-atlassian)
# ============================================
JIRA_URL=
JIRA_USERNAME=
JIRA_PERSONAL_TOKEN=
CONFLUENCE_URL=
CONFLUENCE_USERNAME=
CONFLUENCE_PERSONAL_TOKEN=

# ============================================
# Security / CORS
# ============================================
SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
CORS_ORIGINS=http://localhost
