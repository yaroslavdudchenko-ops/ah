# Synthia — AI Clinical Protocol Generator
# Copy to .env and fill in all CHANGE_ME values
# DO NOT commit .env to version control

# ============================================
# Application
# ============================================
APP_ENV=development
LOG_LEVEL=info
APP_DOMAIN=localhost

# ============================================
# Database — PostgreSQL
# ============================================
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=protocols

# ============================================
# AI — Internal Gateway (ONLY allowed, NFR-08)
# Production: https://aigateway.biocad.ru/api/v2
# Local dev:  http://host.docker.internal:11434
# ============================================
AI_GATEWAY_URL=http://host.docker.internal:11434
AI_GATEWAY_API_KEY=CHANGE_ME
AI_GATEWAY_MODEL=InHouse/Qwen3.5-122B

# ============================================
# Security
# ============================================
SECRET_KEY=CHANGE_ME_TO_32_RANDOM_BYTES

# ============================================
# Demo users (RBAC)
# ============================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME
EMPLOYEE_USERNAME=employee
EMPLOYEE_PASSWORD=CHANGE_ME
AUDITOR_USERNAME=auditor
AUDITOR_PASSWORD=CHANGE_ME

# ============================================
# CORS — set to public domain in Dokploy
# Example: '["https://synthia.dokploy.biocad.ru"]'
# ============================================
CORS_ORIGINS=["http://localhost","http://localhost:80"]

# ============================================
# GitLab MCP
# ============================================
GITLAB_API_URL=https://gitlab.biocad.ru
GITLAB_PERSONAL_ACCESS_TOKEN=CHANGE_ME
