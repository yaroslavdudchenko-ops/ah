# ================================================================
# Synthia - AI Protocol Generator
# Шаблон переменных окружения для Dokploy
# Вставляй в Dokploy UI -> Environment (по одной переменной)
# НИКОГДА не коммить .env с реальными значениями в git
# ================================================================

# == ОБЯЗАТЕЛЬНЫЕ (деплой не запустится без них) ==============
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=protocols
DATABASE_URL=postgresql+asyncpg://app:CHANGE_ME_strong_password_here@db:5432/protocols

SECRET_KEY=CHANGE_ME_at_least_32_random_chars_here_1234

AI_GATEWAY_URL=https://ai-gateway.internal/v1
AI_GATEWAY_API_KEY=your-ai-gateway-key-here

# == CORS (comma-separated, без JSON-скобок и кавычек!) ========
CORS_ORIGINS=https://your-domain.traefik.me,http://localhost

# == Необязательные (есть дефолты в compose) ==================
AI_GATEWAY_MODEL=InHouse/Qwen3.5-122B
LOG_LEVEL=info
APP_ENV=development

# == Учётные записи (переопредели дефолты) ====================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_admin_password
EMPLOYEE_USERNAME=employee
EMPLOYEE_PASSWORD=CHANGE_ME_employee_password
AUDITOR_USERNAME=auditor
AUDITOR_PASSWORD=CHANGE_ME_auditor_password
