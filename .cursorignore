# ============================================================================
# CURSOR AI - ФАЙЛ ИСКЛЮЧЕНИЙ ДЛЯ БЕЗОПАСНОСТИ
# ============================================================================
# Версия: 1.0.0
# Последнее обновление: Февраль 2026
# Назначение: Предотвращение утечки конфиденциальных данных в LLM
#
# ВАЖНО: Файлы, перечисленные здесь, НЕ ОТПРАВЛЯЮТСЯ в AI-модель и
# НЕ ИНДЕКСИРУЮТСЯ для векторной базы знаний (RAG).
#
# ВНИМАНИЕ: Даже если файл указан в .cursorignore, Cursor МОЖЕТ прочитать его,
# если он открыт в редакторе. Закрывайте конфиденциальные файлы после работы.
# ============================================================================

# ----------------------------------------------------------------------------
# 1. СЕКРЕТЫ И УЧЁТНЫЕ ДАННЫЕ (КРИТИЧНЫЙ ПРИОРИТЕТ)
# ----------------------------------------------------------------------------
# Риск: КРИТИЧЕСКИЙ — прямая утечка credentials -> компрометация систем
# ----------------------------------------------------------------------------

# Environment переменные
.env
.env.*
.env.local
.env.production
.env.staging
.env.development
.env.test

# SSH ключи и сертификаты
*.key
*.pem
*.cert
*.crt
*.p12
*.pfx
id_rsa
id_dsa
id_ecdsa
id_ed25519
known_hosts

# Cloud credentials
.aws/credentials
.aws/config
.azure/credentials
.gcloud/credentials.json
gcloud-service-key.json

# Secrets management
secrets/
credentials/
vault/
.secrets/
config/master.key
config/credentials.yml.enc

# Kubernetes secrets (при локальной работе)
*secret*.yaml
*secret*.yml
kubeconfig

# Базы данных с credentials
# database.yml
# database.json
# connection-strings.txt

# ----------------------------------------------------------------------------
# 2. БИЗНЕС-ЛОГИКА И ИНТЕЛЛЕКТУАЛЬНАЯ СОБСТВЕННОСТЬ
# ----------------------------------------------------------------------------
# Риск: ВЫСОКИЙ — утечка IP -> потеря конкурентного преимущества
# ----------------------------------------------------------------------------

# Внутренняя документация
docs/internal/
docs/confidential/
docs/architecture/sensitive/
# wiki/private/
# design-docs/proprietary/

# Проприетарные алгоритмы (настройте под свой проект)
# src/core/payment-processing/
# src/algorithms/proprietary/
# lib/internal/
# packages/private/

# ----------------------------------------------------------------------------
# 3. ПЕРСОНАЛЬНЫЕ ДАННЫЕ
# ----------------------------------------------------------------------------
# Риск: КРИТИЧЕСКИЙ — утечка PII -> нарушение законодательства
# ----------------------------------------------------------------------------

# Экспорты пользовательских данных
user-data/
exports/*.csv
exports/*.xlsx
backups/users/
dumps/production/

# Логи с персональными данными
logs/*production*.log
logs/*user*.log
# access.log
# audit.log

# Тестовые данные с реальными именами/emails
# test-data/real-users/
# fixtures/production-data/

# ----------------------------------------------------------------------------
# 4. ЗАВИСИМОСТИ И АРТЕФАКТЫ СБОРКИ
# ----------------------------------------------------------------------------
# Риск: СРЕДНИЙ — скрытие вредоносных пакетов, раздувание контекста
# ----------------------------------------------------------------------------

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Python
venv/
env/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.tox/

# Go
vendor/

# Ruby
.bundle/

# Java/Kotlin
target/
build/
*.jar
*.war

# .NET
bin/
obj/
*.dll
*.exe

# Rust
target/

# Build outputs
dist/
out/
coverage/
.next/
.nuxt/
.cache/

# ----------------------------------------------------------------------------
# 5. IDE И СИСТЕМНЫЕ ФАЙЛЫ
# ----------------------------------------------------------------------------
# Риск: НИЗКИЙ — утечка информации о файловой системе
# ----------------------------------------------------------------------------

# JetBrains
.idea/
*.iml

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
.directory

# ----------------------------------------------------------------------------
# 6. ЛОГИ И ВРЕМЕННЫЕ ФАЙЛЫ
# ----------------------------------------------------------------------------
# Риск: СРЕДНИЙ — стектрейсы могут содержать секреты
# ----------------------------------------------------------------------------

# Логи
*.log
logs/
log/

# Crash dumps
*.dmp
*.dump
core.*

# Временные файлы
tmp/
temp/
*.tmp
*.swp
*.swo

# ----------------------------------------------------------------------------
# 7. БАЗЫ ДАННЫХ
# ----------------------------------------------------------------------------
# Риск: КРИТИЧЕСКИЙ — PII, credentials
# ----------------------------------------------------------------------------

# SQLite
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal

# SQL дампы
dump.sql
backup.sql

# Redis dumps
dump.rdb

# ----------------------------------------------------------------------------
# 8. МЕДИА И БОЛЬШИЕ ФАЙЛЫ
# ----------------------------------------------------------------------------
# Риск: НИЗКИЙ — раздувание контекста, возможная утечка контента
# ----------------------------------------------------------------------------

# Пользовательские загрузки
uploads/
user-uploads/

# Видео
*.mp4
*.avi
*.mov

# Архивы
*.zip
*.tar.gz
*.rar
*.7z

