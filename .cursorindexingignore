# ============================================================================
# CURSOR AI - ИСКЛЮЧЕНИЯ ДЛЯ ИНДЕКСАЦИИ
# ============================================================================
# Версия: 1.0.0
# Назначение: Файлы, которые НЕ индексируются в векторную базу (RAG),
#             но МОГУТ быть видны AI, если открыты в редакторе.
#
# Разница с .cursorignore:
# - .cursorignore: AI НИКОГДА не видит эти файлы
# - .cursorindexingignore: AI не индексирует, но может читать если открыты
# ============================================================================

# Тесты (не нужны в контексте при работе над feature)
**/__tests__/**
**/*.test.ts
**/*.test.js
**/*.test.py
**/*.spec.ts
**/*.spec.js

# CI/CD конфигурации
.gitlab-ci.yml

